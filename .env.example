# Copy this file to `.env` in the project root. Vite does NOT read `.env.example` — only `.env` (and `.env.local`, etc.).
# After copying, restart `npm run dev`.
#
# Supabase: Project Settings → API — use Project URL and the anon public key.
# Optional: VITE_SUPABASE_PROJECT_ID is not used by the app code; URL + publishable key are enough.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
